# -----------------------------
# App profile
# -----------------------------
APP_PROFILE=development
TIMEZONE=America/Sao_Paulo

# -----------------------------
# Portas publicas no host
# -----------------------------
APP_EXTERNAL_PORT=8080
DB_EXTERNAL_PORT=3306

# -----------------------------
# Banco MySQL
# -----------------------------
MYSQL_DATABASE=FichaTecnica
MYSQL_USER=ficha_app
MYSQL_PASSWORD=troque-esta-senha
MYSQL_ROOT_PASSWORD=troque-esta-senha-root

# -----------------------------
# JWT e seguranca
# -----------------------------
JWT_SECRET=troque-para-um-segredo-forte
JWT_EXPIRATION_MINUTES=120

# -----------------------------
# Frontend autorizado (CORS)
# -----------------------------
SITE_ORIGIN_ALLOWED=http://localhost:4200

# -----------------------------
# E-mail (opcional)
# -----------------------------
MAIL_HOST=smtp.zoho.com
MAIL_PORT=465
MAIL_USER=
MAIL_PWD=
SYSTEM_USER=
SYSTEM_PWD=

