# -----------------------------
# App profile e timezone
# -----------------------------
APP_PROFILE=production
TIMEZONE=America/Sao_Paulo

# -----------------------------
# Porta publica do backend
# -----------------------------
APP_EXTERNAL_PORT=8080

# -----------------------------
# Banco (sem senha em texto)
# -----------------------------
MYSQL_DATABASE=FichaTecnica
MYSQL_USER=ficha_app
DB_EXTERNAL_PORT=3306

# -----------------------------
# Segredos via arquivos
# Ajuste os caminhos para arquivos reais fora do git.
# -----------------------------
MYSQL_PASSWORD_FILE=./docker/secrets/mysql_password.txt
MYSQL_ROOT_PASSWORD_FILE=./docker/secrets/mysql_root_password.txt
JWT_SECRET_FILE=./docker/secrets/jwt_secret.txt
MAIL_PWD_FILE=./docker/secrets/mail_pwd.txt
SYSTEM_PWD_FILE=./docker/secrets/system_pwd.txt

# -----------------------------
# Configuracoes nao secretas
# -----------------------------
JWT_EXPIRATION_MINUTES=120
SITE_ORIGIN_ALLOWED=https://seu-frontend.exemplo.com
MAIL_HOST=smtp.zoho.com
MAIL_PORT=465
MAIL_USER=
SYSTEM_USER=

